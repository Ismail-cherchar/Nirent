# ─────────────────────────────────────────────────────────────
#  Variables d'environnement — Nirent
#  Copier ce fichier en « .env.local » puis renseigner les valeurs.
#  Ne JAMAIS committer .env.local (déjà exclu via .gitignore).
# ─────────────────────────────────────────────────────────────

# Identifiant de l'application Base44 (OBLIGATOIRE)
VITE_BASE44_APP_ID=votre_app_id

# URL de base du back-end Base44 (OBLIGATOIRE)
# Exemple : https://nirent-xxxxxxxx.base44.app
VITE_BASE44_APP_BASE_URL=votre_backend_url

# Version des fonctions Base44 (OPTIONNEL — laisser vide si non utilisé)
VITE_BASE44_FUNCTIONS_VERSION=

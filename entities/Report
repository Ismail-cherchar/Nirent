{
  "name": "Report",
  "type": "object",
  "properties": {
    "booking_id": {
      "type": "string"
    },
    "reporter_email": {
      "type": "string"
    },
    "reporter_name": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "damage",
        "late_return",
        "fraud",
        "other"
      ]
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "in_progress",
        "resolved"
      ],
      "default": "open"
    },
    "photos": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "booking_id",
    "reporter_email",
    "type",
    "description"
  ]
}